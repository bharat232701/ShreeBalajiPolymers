<svg width="100" height="100" viewBox="0 0 100 100" xmlns="http://www.w3.org/2000/svg">
  <!-- Navy蓝色圆圈 -->
  <circle cx="25" cy="50" r="10" fill="#00337A"></circle>
  <circle cx="50" cy="50" r="10" fill="#00337A"></circle>
  <circle cx="75" cy="50" r="10" fill="#00337A"></circle>
  <!-- White连接线 -->
  <line x1="25" y1="50" x2="50" y2="50" stroke="#FFFFFF" stroke-width="3"></line>
  <line x1="50" y1="50" x2="75" y2="50" stroke="#FFFFFF" stroke-width="3"></line>
  <!-- SBP文字 -->
  <text x="50" y="85" font-family="Arial, sans-serif" font-size="18" font-weight="bold" fill="#00337A" text-anchor="middle">
    SBP
  </text>
</svg>